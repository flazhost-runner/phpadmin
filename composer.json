{
    "name": "phpadmin/phpadmin",
    "description": "PHPAdmin — PHP 8.3+ native admin bootstrap",
    "type": "project",
    "require": {
        "php": "^8.3",
        "aws/aws-sdk-php": "^3.0",
        "firebase/php-jwt": "^7.1",
        "illuminate/database": "^13.17",
        "illuminate/pagination": "^13.17",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.1",
        "phpmailer/phpmailer": "^7.1",
        "predis/predis": "^3.5",
        "respect/validation": "^2.4",
        "robmorgan/phinx": "^0.16.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.2",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "PHPAdmin\\": "src/"
        },
        "classmap": [
            "src/Core/Exceptions/AppException.php"
        ],
        "files": [
            "src/Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PHPAdmin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -d opcache.enable=0 -S 0.0.0.0:8001 -t public public/index.php",
        "test": "phpunit",
        "check": [
            "./vendor/bin/phpstan analyse src --level=6 --no-progress",
            "./vendor/bin/phpcs src --standard=phpcs.xml -q"
        ],
        "migrate": "./vendor/bin/phinx migrate",
        "migrate:rollback": "./vendor/bin/phinx rollback",
        "migrate:status": "./vendor/bin/phinx status",
        "make-module": "php bin/make_module"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        }
    },
    "minimum-stability": "stable"
}
