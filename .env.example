# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=PHPAdmin
APP_ENV=development
APP_PORT=8000
# Modes: full (sessions+CSRF+Redis) | api (API-only, no session)
APP_MODE=full
APP_URL=http://localhost:8000

# ─── Database ─────────────────────────────────────────────────────────────────
# Drivers: mysql | pgsql | sqlite
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=phpadmin
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ─── Redis ────────────────────────────────────────────────────────────────────
# Gunakan rediss:// untuk TLS (managed Redis di balik proxy SNI). Skema rediss://
# mengaktifkan TLS + mengirim SNI servername (peer_name = host) secara otomatis.
# Contoh: REDIS_URL=rediss://default:<pw>@u<hash>-<alias>.redis.db.flazhost.com:6380
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=
# Jika memakai REDIS_HOST/REDIS_PORT (bukan REDIS_URL), set REDIS_TLS=true untuk TLS.
# REDIS_TLS=false

# ─── Session & Auth ───────────────────────────────────────────────────────────
# SESSION_DRIVER: redis | database
# - redis    : simpan sesi di Redis (default). Sesi hilang saat Redis restart.
# - database : simpan sesi di tabel `sessions` DB utama. Persist lintas restart.
#              Jalankan migration dulu: php vendor/bin/phinx migrate
SESSION_DRIVER=database
SESSION_SECRET=change_me_to_at_least_32_characters_long
SESSION_TTL_HOURS=6
JWT_SECRET=change_me_to_at_least_32_characters_long
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
DEFAULT_PAGE_SIZE=10

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=PHPAdmin

# ─── Storage (file manager) ───────────────────────────────────────────────────
# Drivers: local | oss | s3
# - local : simpan ke filesystem lokal (STORAGE_BASE_PATH).
# - oss   : Alibaba OSS atau S3-compatible.
# - s3    : AWS S3 atau S3-compatible (MinIO, R2, dll).
STORAGE_DRIVER=local
STORAGE_BASE_PATH=storage/uploads
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=us-east-1
STORAGE_SSL=true
# false = virtual-hosted style (AWS S3, Alibaba OSS, DigitalOcean Spaces)
# true  = path-style (MinIO lokal, beberapa S3-compat lain)
STORAGE_PATH_STYLE=false
STORAGE_BASE_URL=

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=UTC
